# =============================================================================
# AuraDev ERP API — Environment
# =============================================================================

# Local dev
# spring.profiles.active=dev

# Production (Railway / Render) — REQUIRED
SPRING_PROFILES_ACTIVE=prod

PORT=8080

DB_URL=jdbc:postgresql://db.<project-ref>.supabase.co:5432/postgres
DB_USERNAME=postgres
DB_PASSWORD=your-database-password

# Generate: openssl rand -base64 48  (min 32 bytes)
JWT_SECRET=replace-with-a-long-random-base64-string

# Frontend URL only — blocks other origins from calling the API directly
# Example: https://auradev-erp.onrender.com
CORS_ALLOWED_ORIGINS=https://your-frontend.onrender.com

# Public API URL (logo links in settings responses)
APP_PUBLIC_BASE_URL=https://your-api.railway.app

# Persistent disk on Render/Railway (mount volume here)
APP_UPLOADS_DIR=/var/data/uploads
